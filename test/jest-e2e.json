{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testMatch": ["<rootDir>/test/**/*.e2e-spec.ts"],
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "testEnvironment": "node",
  "moduleNameMapper": {
    "^@shared/(.*)$": "<rootDir>/src/shared/$1",
    "^@iam/(.*)$": "<rootDir>/src/contexts/iam/$1",
    "^@infrastructure/(.*)$": "<rootDir>/src/infrastructure/$1"
  }
}
