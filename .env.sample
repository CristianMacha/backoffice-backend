# Application
NODE_ENV=development
PORT=3000
# Comma-separated allowed CORS origins. Empty string blocks all browser clients.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Database (PostgreSQL)
# When using Docker Compose: DB_HOST=postgres
# When running locally:      DB_HOST=localhost
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=dolphin_dev
DB_SSL=false

# Bootstrap admin (optional — only needed on first deploy)
# Create a user in Firebase Console → Authentication → Add user, then copy their UID here.
# The seed will create that user in the DB with the super_admin role.
# Once the admin exists, leave these empty — the seed is idempotent and will skip creation.
SUPER_ADMIN_FIREBASE_UID=
SUPER_ADMIN_EMAIL=

# Setup flow:
#   1. cp .env.sample .env  (fill in all values)
#   2. pnpm migration:run   (creates tables)
#   3. pnpm seed            (inserts roles + permissions + bootstrap admin if set)
#   4. pnpm start:dev

# Firebase Admin SDK
# Get these from Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Paste the private key value exactly — newlines are encoded as \n in .env files
FIREBASE_PRIVATE_KEY=
